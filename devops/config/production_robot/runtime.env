# BonBon runtime environment — production_robot
# Host/user/channel are deployment metadata; all secrets are runtime-injected
# and a rollback version must be present (enforced by pre_deploy_check.py).
BONBON_ENV=production_robot
BONBON_SIMULATION=false
BONBON_ROBOT_HOST=bonbon-prod-01.local
BONBON_ROBOT_USER=bonbon
BONBON_RELEASE_CHANNEL=stable
BONBON_DATA_DIR=/var/bonbon/data
BONBON_LOG_LEVEL=warn
