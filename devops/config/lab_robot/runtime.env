# BonBon runtime environment — lab_robot (real hardware, lab network)
# Host/user are deployment metadata (override per machine); secrets stay runtime.
BONBON_ENV=lab_robot
BONBON_SIMULATION=false
BONBON_ROBOT_HOST=lab-bonbon-01.local
BONBON_ROBOT_USER=bonbon
BONBON_DATA_DIR=/var/bonbon/data
BONBON_LOG_LEVEL=info
