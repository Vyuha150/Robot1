# BonBon runtime environment — local_dev
# Non-secret deployment metadata only. Secrets (BONBON_JWT_SECRET,
# BONBON_ADMIN_PASSWORD) are injected at runtime, never committed.
BONBON_ENV=local_dev
BONBON_SIMULATION=true
BONBON_DATA_DIR=/var/bonbon/data
BONBON_LOG_LEVEL=debug
BONBON_ENABLE_OPERATOR_API=true
