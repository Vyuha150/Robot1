FROM ros:humble-ros-base-jammy

SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ENV DEBIAN_FRONTEND=noninteractive \
    ROS_DISTRO=humble \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip python3-colcon-common-extensions python3-rosdep \
    python3-numpy git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/bonbon
COPY ros2_ws/src/bonbon_llm /opt/bonbon/ros2_ws/src/bonbon_llm
COPY ros2_ws/src/bonbon_perception_ai /opt/bonbon/ros2_ws/src/bonbon_perception_ai
COPY ros2_ws/src/bonbon_msgs /opt/bonbon/ros2_ws/src/bonbon_msgs
RUN source /opt/ros/humble/setup.bash && colcon build --base-paths ros2_ws/src --merge-install

RUN useradd --create-home --shell /bin/bash bonbon && chown -R bonbon:bonbon /opt/bonbon
USER bonbon
VOLUME ["/models"]
ENTRYPOINT ["/bin/bash", "-lc"]
CMD ["source /opt/ros/humble/setup.bash && source /opt/bonbon/install/setup.bash && ros2 launch bonbon_llm llm.launch.py"]
