{
  "uid": "bonbon-navigation-performance",
  "title": "BonBon Navigation Performance",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["bonbon", "navigation"],
  "panels": [
    {"type": "stat", "title": "Navigation Failures", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "increase(bonbon_navigation_failures_total[1h])"}]},
    {"type": "stat", "title": "Replanning Latency p95", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "histogram_quantile(0.95, rate(bonbon_navigation_replanning_latency_seconds_bucket[5m]))"}]},
    {"type": "timeseries", "title": "Path Deviation", "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "targets": [{"expr": "bonbon_navigation_path_deviation_meters"}]},
    {"type": "timeseries", "title": "ROS2 Node Health", "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "targets": [{"expr": "bonbon_ros2_node_health"}]}
  ]
}
