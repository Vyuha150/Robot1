<?xml version="1.0"?>
<robot name="bonbon" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="length_m" default="0.72"/>
  <xacro:arg name="width_m" default="0.48"/>
  <xacro:arg name="height_m" default="1.15"/>
  <xacro:arg name="wheel_radius_m" default="0.075"/>
  <xacro:arg name="wheel_separation_m" default="0.42"/>

  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <collision>
      <geometry><box size="$(arg length_m) $(arg width_m) 0.24"/></geometry>
    </collision>
    <visual>
      <geometry><box size="$(arg length_m) $(arg width_m) 0.24"/></geometry>
      <material name="bonbon_white"><color rgba="0.92 0.95 0.96 1"/></material>
    </visual>
    <inertial><mass value="28.0"/><origin xyz="0 0 0"/><inertia ixx="1.2" ixy="0" ixz="0" iyy="1.5" iyz="0" izz="1.8"/></inertial>
  </link>

  <link name="left_wheel_link">
    <collision><geometry><cylinder radius="$(arg wheel_radius_m)" length="0.045"/></geometry></collision>
    <visual><geometry><cylinder radius="$(arg wheel_radius_m)" length="0.045"/></geometry></visual>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.21 -0.07" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel_link">
    <collision><geometry><cylinder radius="$(arg wheel_radius_m)" length="0.045"/></geometry></collision>
    <visual><geometry><cylinder radius="$(arg wheel_radius_m)" length="0.045"/></geometry></visual>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.21 -0.07" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="torso_link">
    <collision><geometry><cylinder radius="0.18" length="0.75"/></geometry></collision>
    <visual><geometry><cylinder radius="0.18" length="0.75"/></geometry></visual>
  </link>
  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso_link"/>
    <origin xyz="0 0 0.48" rpy="0 0 0"/>
  </joint>

  <link name="head_link">
    <collision><geometry><box size="0.28 0.22 0.18"/></geometry></collision>
    <visual><geometry><box size="0.28 0.22 0.18"/></geometry></visual>
  </link>
  <joint name="head_pan_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 0.45" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="4" velocity="1.2"/>
  </joint>

  <link name="lidar_link"/>
  <joint name="lidar_joint" type="fixed"><parent link="base_link"/><child link="lidar_link"/><origin xyz="0.22 0 0.18" rpy="0 0 0"/></joint>
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin xyz="0 0 0.14" rpy="0 0 0"/></joint>
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed"><parent link="head_link"/><child link="camera_link"/><origin xyz="0.16 0 0.02" rpy="0 0 0"/></joint>
  <link name="microphone_link"/>
  <joint name="microphone_joint" type="fixed"><parent link="head_link"/><child link="microphone_link"/><origin xyz="0.08 0.08 0.03" rpy="0 0 0"/></joint>
  <link name="speaker_link"/>
  <joint name="speaker_joint" type="fixed"><parent link="torso_link"/><child link="speaker_link"/><origin xyz="0.12 0 0.1" rpy="0 0 0"/></joint>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>$(arg wheel_separation_m)</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <command_topic>/bonbon/safety_gate/cmd_vel</command_topic>
      <odometry_topic>/odom</odometry_topic>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>
</robot>
