# Copy to .env on deployment hosts. Never commit .env.
BONBON_ENV=local_dev
BONBON_IMAGE_TAG=dev
BONBON_ROBOT_HOST=
BONBON_ROBOT_USER=bonbon
BONBON_ROBOT_SSH_PORT=22
BONBON_MIN_BATTERY_PCT=40
BONBON_RELEASE_CHANNEL=dev
BONBON_CONFIG_DIR=/etc/bonbon
BONBON_DATA_DIR=/var/lib/bonbon
BONBON_LOG_DIR=/var/log/bonbon
BONBON_MODEL_DIR=/opt/bonbon/models
BONBON_MAP_DIR=/opt/bonbon/maps
BONBON_DASHBOARD_PORT=8080
BONBON_PROMETHEUS_PORT=9090
BONBON_GRAFANA_PORT=3000
# Required at runtime only:
# BONBON_JWT_SECRET=
# BONBON_ADMIN_PASSWORD=
